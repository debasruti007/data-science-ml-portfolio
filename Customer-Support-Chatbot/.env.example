# ════════════════════════════════════════════════════════════════════════
# Customer Support Chatbot — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-random-32-bytes-in-production
API_RATE_LIMIT=100           # Requests per minute per client

# ── Company Configuration ─────────────────────────────────────────────────────
COMPANY_NAME=AcmeCorp Support
SUPPORT_EMAIL=support@yourcompany.com

# ── Authentication ────────────────────────────────────────────────────────────
ENABLE_AUTH=true             # Set false ONLY for local development
ADMIN_API_KEY=               # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── LLM Providers (at least one required) ─────────────────────────────────────
LLM_PROVIDER=openai          # openai | anthropic
OPENAI_API_KEY=sk-...        # Required if LLM_PROVIDER=openai
ANTHROPIC_API_KEY=           # Required if LLM_PROVIDER=anthropic
COHERE_API_KEY=              # Optional: enables best-quality reranking

# ── Model Selection ───────────────────────────────────────────────────────────
CHAT_MODEL=gpt-4o            # or: gpt-4o-mini, claude-3-sonnet-20240229
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
RERANKER_MODEL=rerank-english-v3.0

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE_TYPE=chroma     # chroma | faiss | pinecone
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=support_docs

# Pinecone (only if VECTOR_STORE_TYPE=pinecone)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=customer-support

# ── Keyword Search ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_INDEX=support_docs

# ── Storage ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://chatbot:changeme@localhost:5432/chatbot_db

# ── Database Pool ─────────────────────────────────────────────────────────────
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── RAG Parameters ────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5
SIMILARITY_THRESHOLD=0.7
MAX_CONTEXT_TOKENS=4096
MAX_RESPONSE_TOKENS=1024
CHECK_HALLUCINATION=false
HALLUCINATION_THRESHOLD=0.7
ENABLE_QUERY_EXPANSION=false

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_CHUNK_SIZE=100

# ── Conversations ─────────────────────────────────────────────────────────────
MAX_CONVERSATION_TURNS=20
CONVERSATION_TTL_SECONDS=3600

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Observability ─────────────────────────────────────────────────────────────
ENABLE_TRACING=false
OTLP_ENDPOINT=http://localhost:4317

# ── External Services (Docker Compose) ───────────────────────────────────────
POSTGRES_PASSWORD=changeme-use-strong-password
ELASTIC_PASSWORD=changeme-use-strong-password
GRAFANA_PASSWORD=changeme-use-strong-password