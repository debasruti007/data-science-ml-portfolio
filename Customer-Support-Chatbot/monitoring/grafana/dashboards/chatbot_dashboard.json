{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "Customer Support Chatbot Monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Request Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(http_requests_total{job='chatbot'}[5m])",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "ms"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "title": "P95 Latency",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job='chatbot'}[5m])) * 1000",
          "legendFormat": "p95 ms"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "percentunit"},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(http_requests_total{job='chatbot',status=~'5..'}[5m]) / rate(http_requests_total{job='chatbot'}[5m])",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "ms"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "id": 4,
      "title": "Request Latency Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job='chatbot'}[5m])) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job='chatbot'}[5m])) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job='chatbot'}[5m])) * 1000",
          "legendFormat": "p99"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["chatbot", "rag", "ai"],
  "title": "Customer Support Chatbot",
  "uid": "chatbot-v1",
  "version": 1
}